<?xml version="1.0" encoding="UTF-8"?>
<definition:ConnectorDefinition
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:definition="http://www.bonitasoft.org/ns/connector/definition/6.1">

  <id>${hubspot-update-deal.def.id}</id>
  <version>${hubspot-update-deal.def.version}</version>
  <icon>hubspot.png</icon>
  <category icon="hubspot.png" id="HubSpot CRM"/>

  <input name="authMode" type="java.lang.String" mandatory="false" defaultValue="PRIVATE_APP"/>
  <input name="privateAppToken" type="java.lang.String" mandatory="false"/>
  <input name="clientId" type="java.lang.String" mandatory="false"/>
  <input name="clientSecret" type="java.lang.String" mandatory="false"/>
  <input name="refreshToken" type="java.lang.String" mandatory="false"/>
  <input name="basePath" type="java.lang.String" mandatory="false" defaultValue="https://api.hubapi.com"/>
  <input name="connectTimeout" type="java.lang.Integer" mandatory="false" defaultValue="30000"/>
  <input name="readTimeout" type="java.lang.Integer" mandatory="false" defaultValue="60000"/>
  <input name="dealId" type="java.lang.String" mandatory="true"/>
  <input name="dealStage" type="java.lang.String" mandatory="false"/>
  <input name="amount" type="java.lang.String" mandatory="false"/>
  <input name="closeDate" type="java.lang.String" mandatory="false"/>
  <input name="dealOwnerId" type="java.lang.String" mandatory="false"/>
  <input name="customProperties" type="java.lang.String" mandatory="false"/>

  <output name="dealId" type="java.lang.String"/>
  <output name="dealStage" type="java.lang.String"/>
  <output name="updatedAt" type="java.lang.String"/>
  <output name="success" type="java.lang.Boolean"/>
  <output name="errorMessage" type="java.lang.String"/>

  <page id="connectionPage">
    <widget xsi:type="definition:Select" id="authModeWidget" inputName="authMode"/>
    <widget xsi:type="definition:Password" id="privateAppTokenWidget" inputName="privateAppToken"/>
    <widget xsi:type="definition:Text" id="clientIdWidget" inputName="clientId"/>
    <widget xsi:type="definition:Password" id="clientSecretWidget" inputName="clientSecret"/>
    <widget xsi:type="definition:Password" id="refreshTokenWidget" inputName="refreshToken"/>
    <widget xsi:type="definition:Text" id="basePathWidget" inputName="basePath"/>
    <widget xsi:type="definition:Text" id="connectTimeoutWidget" inputName="connectTimeout"/>
    <widget xsi:type="definition:Text" id="readTimeoutWidget" inputName="readTimeout"/>
  </page>
  <page id="operationPage">
    <widget xsi:type="definition:Text" id="dealIdWidget" inputName="dealId"/>
    <widget xsi:type="definition:Text" id="dealStageWidget" inputName="dealStage"/>
    <widget xsi:type="definition:Text" id="amountWidget" inputName="amount"/>
    <widget xsi:type="definition:Text" id="closeDateWidget" inputName="closeDate"/>
    <widget xsi:type="definition:Text" id="dealOwnerIdWidget" inputName="dealOwnerId"/>
  </page>
  <page id="additionalPage">
    <widget xsi:type="definition:TextArea" id="customPropertiesWidget" inputName="customProperties"/>
  </page>
</definition:ConnectorDefinition>
